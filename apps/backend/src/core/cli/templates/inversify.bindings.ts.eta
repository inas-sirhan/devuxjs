<% if (it.generateRepo) { %>import { setup<%= it.repoNamePascalCase %>RepoBindings } from '@/__internals__/domains/<%= it.domainNameKebabCase %>/endpoints/<%= it.endpointIdKebabCase %>/repos/<%= it.repoNameKebabCase %>/<%= it.repoNameKebabCase %>.repo.inversify.bindings';
<% } %>import { <%= it.endpointIdPascalCase %>UseCase } from '@/domains/<%= it.domainNameKebabCase %>/endpoints/<%= it.endpointIdKebabCase %>/<%= it.endpointIdKebabCase %>.use-case';
