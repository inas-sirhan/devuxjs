{
  "name": "backend",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "check": "tsc --noEmit && eslint . --max-warnings=0",
    "check:fix": "eslint . --fix --max-warnings=0 && tsc --noEmit",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "lint:fix:dry": "eslint . --fix-dry-run --max-warnings=0",
    "build": "tsc --noEmit && eslint . --max-warnings=0 && node build.js",
    "build:force": "node build.js",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "dev:test": "cross-env NODE_ENV=test tsx watch src/index.ts",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:test": "cross-env NODE_ENV=test node dist/index.js",
    "test": "vitest run",
    "test:e2e-only": "vitest run --include '**/*.e2e.test.ts'",
    "test:without-e2e": "vitest run --exclude '**/*.e2e.test.ts'",
    "test:coverage": "vitest run --coverage",
    "devux": "tsx src/core/cli/cli.ts",
    "visualize": "tsx src/core/cli/visualizer/visualize.ts",
    "gen-db-table": "tsx src/core/tools/drizzle/drizzle.generator.ts",
    "sync:api": "cross-env NODE_ENV=test SYNC_API=true tsx src/index.ts",
    "sync:db": "tsx src/core/tools/sync-database.ts",
    "view-api": "tsx src/core/tools/view-api.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@clack/prompts": "1.0.0-alpha.7",
    "@eslint/js": "9.34.0",
    "@orval/core": "7.11.2",
    "@scalar/cli": "1.3.7",
    "@types/express": "5.0.2",
    "@types/multer": "2.0.0",
    "@types/node": "22.17.2",
    "@types/pg": "8.15.5",
    "@types/qs": "6.14.0",
    "@typescript-eslint/eslint-plugin": "8.40.0",
    "@typescript-eslint/parser": "8.40.0",
    "@vitest/coverage-v8": "3.2.4",
    "cross-env": "10.1.0",
    "drizzle-kit": "0.31.4",
    "drizzle-orm": "0.43.1",
    "esbuild": "0.25.9",
    "eslint": "9.34.0",
    "eslint-plugin-import-zod": "1.2.1",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-sonarjs": "3.0.5",
    "eslint-plugin-unused-imports": "4.3.0",
    "eta": "4.0.1",
    "fetch-cookie": "3.1.0",
    "globals": "16.3.0",
    "kysely-codegen": "0.18.5",
    "open-cli": "8.0.0",
    "ts-morph": "26.0.0",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "typescript-eslint": "8.40.0",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "7.3.4",
    "@packages/shared": "workspace:*",
    "dotenv": "17.2.2",
    "express": "5.1.0",
    "inversify": "7.7.0",
    "kysely": "0.28.3",
    "multer": "2.0.2",
    "pg": "8.16.3",
    "qs": "6.14.0",
    "reflect-metadata": "0.2.2",
    "zod": "3.25.67"
  }
}
